{
  "@context": {
    "@version": 1.1,
    "beckn":              "https://schema.beckn.io/",
    "Action":             { "@id": "beckn:Action" },
    "Signature":          { "@id": "beckn:Signature" },
    "RequestAction":      { "@id": "beckn:RequestAction" },
    "RequestActionQuery": { "@id": "beckn:RequestActionQuery" },
    "CallbackAction":     { "@id": "beckn:CallbackAction" },
    "Ack":                { "@id": "beckn:Ack" },
    "Nack":               { "@id": "beckn:Nack" },
    "NackBadRequest":     { "@id": "beckn:NackBadRequest" },
    "NackUnauthorized":   { "@id": "beckn:NackUnauthorized" },
    "NpInternalError":       { "@id": "beckn:NpInternalError" },
    "NetworkParticipant":    { "@id": "beckn:NetworkParticipant" }
  }
}
