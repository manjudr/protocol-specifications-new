{
  "@context": {
    "@version": 1.1,
    "beckn": "https://schema.beckn.io#",
    "rdf":   "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs":  "http://www.w3.org/2000/01/rdf-schema#",
    "owl":   "http://www.w3.org/2002/07/owl#",
    "xsd":   "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:Action",
      "@type": "owl:Class",
      "rdfs:label": "Action",
      "rdfs:comment": "Identifies the specific Beckn protocol operation being performed."
    },
    {
      "@id": "beckn:Signature",
      "@type": "owl:Class",
      "rdfs:label": "Signature",
      "rdfs:comment": "Beckn Signature used for authenticating requests and callbacks."
    },
    {
      "@id": "beckn:RequestAction",
      "@type": "owl:Class",
      "rdfs:label": "RequestAction",
      "rdfs:comment": "A forward Beckn protocol action payload originated by a BAP directed at a BPP or Catalog Discovery Service."
    },
    {
      "@id": "beckn:RequestActionQuery",
      "@type": "owl:Class",
      "rdfs:label": "RequestActionQuery",
      "rdfs:comment": "A Beckn action payload encoded as a URL query parameter for GET Query Mode."
    },
    {
      "@id": "beckn:CallbackAction",
      "@type": "owl:Class",
      "rdfs:label": "CallbackAction",
      "rdfs:comment": "A callback Beckn protocol action payload originated by a BPP directed back at a BAP."
    },
    {
      "@id": "beckn:Ack",
      "@type": "owl:Class",
      "rdfs:label": "Ack",
      "rdfs:comment": "Synchronous acknowledgement confirming receipt and successful signature validation; indicates an asynchronous callback will follow."
    },
    {
      "@id": "beckn:Nack",
      "@type": "owl:Class",
      "rdfs:label": "Nack",
      "rdfs:comment": "Negative acknowledgement indicating the request could not be accepted without any reason provided."
    },
    {
      "@id": "beckn:NackBadRequest",
      "@type": "owl:Class",
      "rdfs:label": "NackBadRequest",
      "rdfs:comment": "Negative acknowledgement indicating the request was malformed or invalid (HTTP 400).",
      "rdfs:subClassOf": { "@id": "beckn:Nack" }
    },
    {
      "@id": "beckn:NackUnauthorized",
      "@type": "owl:Class",
      "rdfs:label": "NackUnauthorized",
      "rdfs:comment": "Negative acknowledgement indicating the request lacked valid authentication credentials (HTTP 401).",
      "rdfs:subClassOf": { "@id": "beckn:Nack" }
    },
    {
      "@id": "beckn:NpInternalError",
      "@type": "owl:Class",
      "rdfs:label": "NpInternalError",
      "rdfs:comment": "Server-side error response indicating an internal failure on the network participant's platform (HTTP 500)."
    },
    {
      "@id": "beckn:NetworkParticipant",
      "@type": "owl:Class",
      "rdfs:label": "NetworkParticipant",
      "rdfs:comment": "A participant in a Beckn-enabled network, such as a Beckn Application Platform (BAP), Beckn Provider Platform (BPP), Catalog Discovery Service, Catalog Publishing Service, or Registry."
    }
  ]
}
